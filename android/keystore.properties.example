# Copy to keystore.properties (gitignored) for signed release APKs.
# Generate keystore once:
#   keytool -genkey -v -keystore release.keystore -alias ssc-release -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=release.keystore
storePassword=REPLACE_WITH_STORE_PASSWORD
keyAlias=ssc-release
keyPassword=REPLACE_WITH_KEY_PASSWORD