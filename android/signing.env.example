# Copy to %USERPROFILE%\.ssc\android-signing.env (created by scripts/create_android_keystore.ps1)
# Never commit real values to git.

SSC_ANDROID_KEYSTORE=C:\Users\YOU\.ssc\ssc-release.jks
SSC_ANDROID_KEYSTORE_PASSWORD=your-strong-password
SSC_ANDROID_KEY_ALIAS=ssc-release
SSC_ANDROID_KEY_PASSWORD=your-strong-password