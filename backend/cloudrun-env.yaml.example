# Cloud Run env vars — copy to cloudrun-env.yaml locally (gitignored).
# Never commit secrets. Rotate JWT_SECRET and SFU_INTERNAL_SECRET quarterly.
SSC_ENV: production
SSC_ENFORCE_INSTALLED_CLIENT: "true"
CORS_ORIGINS: "https://www.supersecurechat.com,https://supersecurechat.com"
JWT_SECRET: "REPLACE_WITH_ROTATED_SECRET"
MONGO_URL: "mongodb+srv://USER:PASS@cluster.mongodb.net/ssc"
REDIS_URL: "redis://HOST:6379"
SSC_SFU_ENABLED: "true"
SSC_SFU_WS_URL: "wss://sfu.supersecurechat.com"
SSC_SFU_INTERNAL_URL: "http://SFU_INTERNAL_IP:4443"
SSC_SFU_INTERNAL_SECRET: "REPLACE_WITH_ROTATED_SFU_SECRET"
SSC_TURN_ENABLED: "true"
SSC_TURN_SECRET: "REPLACE_WITH_ROTATED_TURN_SECRET"
SSC_TURN_REALM: "supersecurechat.com"
SSC_TURN_URIS: "turn:turn.supersecurechat.com:3478?transport=udp,turn:turn.supersecurechat.com:3478?transport=tcp"
SSC_STUN_URIS: "stun:turn.supersecurechat.com:3478"
SSC_TURN_TTL_SECONDS: "86400"
GOOGLE_APPLICATION_CREDENTIALS: "/secrets/firebase/key"
GOOGLE_CLIENT_ID: "WEB_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET: "GOCSPX-REPLACE_ME"
GOOGLE_REDIRECT_URI: "https://api.supersecurechat.com/api/auth/google/callback"
FRONTEND_URL: "https://api.supersecurechat.com"

# Tier D — security & abuse (enabled by default once deployed)
SSC_CAPTCHA_REQUIRED: "true"
SSC_TURNSTILE_SECRET: "REPLACE_WITH_TURNSTILE_SECRET"
SSC_TURNSTILE_SITE_KEY: "REPLACE_WITH_TURNSTILE_SITE_KEY"
SSC_NEW_ACCOUNT_GRACE_HOURS: "24"
SSC_NEW_ACCOUNT_DM_LIMIT: "10"
SSC_NEW_ACCOUNT_DM_WINDOW_SEC: "3600"
SSC_ABUSE_REPORT_THRESHOLD: "3"
SSC_ABUSE_REPORT_WINDOW_HOURS: "24"
SSC_ABUSE_RATE_LIMIT_HOURS: "24"