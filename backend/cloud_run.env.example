# Copy to cloud_run.env (gitignored) — used by scripts/deploy_cloud_run.ps1
# Do NOT commit cloud_run.env

# === REQUIRED ===
MONGO_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=ssc
JWT_SECRET=at-least-48-random-characters-for-production
# Blind contact graph — required in production (never commit real value)
CONTACT_GRAPH_PEPPER=at-least-48-random-characters-for-contact-graph

# Free cloud Redis (required for ENV=production) — https://upstash.com
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379

# Set after first deploy (or leave blank and script fills it)
# CLOUD_RUN_SERVICE_URL=https://ssc-api-xxxxx-ew.a.run.app

# === OPTIONAL (paste from backend/.env) ===
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_EMAIL=admin@ssc.local
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://ssc-api-4jp3wuccwa-ew.a.run.app/api/auth/google/callback
# After api.supersecurechat.com is mapped (TASK P.3), also add that callback in Google Console.
NATIVE_OAUTH_REDIRECT=chat.ssc.secure://app
DESKTOP_OAUTH_REDIRECT=chat.ssc.secure.desktop://auth
CORS_ORIGINS=https://localhost,capacitor://localhost,https://ssc-api-4jp3wuccwa-ew.a.run.app,https://www.supersecurechat.com,https://supersecurechat.com,https://super-chat-b0992.web.app
TURN_USERNAME=
TURN_CREDENTIAL=
TURNSTILE_SITEKEY=
TURNSTILE_SECRET=
TRANSLATION_ENABLED=false
ENV=production