# SSC - Super Secure Chat Backend Environment
# Copy to .env and fill in values. (.env is gitignored.)

# === REQUIRED ===
MONGO_URL=mongodb://localhost:27017
DB_NAME=ssc-dev
JWT_SECRET=dev-only-secret-must-differ-from-production
SSC_PRODUCTION_JWT_SECRET=
CONTACT_GRAPH_PEPPER=change-this-contact-graph-pepper-in-production

# === ENVIRONMENT ===
# development | production
ENV=development
LOG_LEVEL=INFO

# === AIR-GAPPED MODE (Engine 1.6) ===
# When true, blocks third-party egress at runtime (translate, OAuth, FCM, web push, Turnstile).
# Use local MongoDB (not Atlas). For WebRTC, set self-hosted ICE URLs below.
# SSC_AIR_GAPPED_MODE=false
# SSC_AIR_GAPPED_STRICT=false
# SSC_STUN_URLS=stun:your-metal.example.com:3478
# SSC_TURN_URLS=turn:your-metal.example.com:3478

# === DATA RETENTION (Engine 1.3) ===
# Hours before messages, conversations, reads, files, stories auto-delete from MongoDB
SSC_RETENTION_HOURS=24
# Days before pending friend requests expire if unanswered
SSC_FRIEND_REQUEST_PENDING_DAYS=7

# === RATE LIMITING (recommended for production / multi-worker) ===
# Start Redis: cd SSC-main && docker compose up -d redis
# Requires Docker Desktop running on Windows
REDIS_URL=redis://localhost:6379/0

# === CORS (installed apps only — https://localhost is Capacitor APK shell, not a browser tab) ===
CORS_ORIGINS=https://localhost,capacitor://localhost,https://ssc-api-4jp3wuccwa-ew.a.run.app

# === Translation (OFF by default — Engine 1.2) ===
# When false, /api/translate returns 403. Enabling sends DECRYPTED text to third parties (MyMemory/Google).
# SSC vision: keep false in production unless you explicitly accept the privacy tradeoff.
TRANSLATION_ENABLED=false
# TRANSLATION_PROVIDER=mymemory
# TRANSLATION_PROVIDER=google
# TRANSLATION_PROVIDER=none
# GOOGLE_TRANSLATE_API_KEY=

# === WebRTC TURN / ICE (required for calls across networks) ===
TURN_USERNAME=
TURN_CREDENTIAL=

# === Email verification (Q.36 — password register activation link) ===
# EMAIL_VERIFICATION_REQUIRED=false
# PUBLIC_APP_URL=http://localhost:3000
# PUBLIC_APP_URL_HASH_ROUTER=true
# EMAIL_FROM_ADDRESS=noreply@yourdomain.example
# EMAIL_FROM_NAME=SSC
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# CLOUDFLARE_EMAIL_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# === Group call SFU (Phase B — mediasoup; optional until deployed) ===
# SFU_URL=wss://sfu.your-domain.example
# SFU_ENABLED=true

# === Cloudflare Turnstile (recommended for production) ===
TURNSTILE_SITEKEY=
TURNSTILE_SECRET=

# === Web Push (VAPID) — PWA / browser ===
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_EMAIL=admin@ssc.local

# === Native Push (FCM + APNs) — Capacitor Android/iOS ===
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Option A: path to JSON file
# Path relative to backend/ when running uvicorn from backend/
# GOOGLE_APPLICATION_CREDENTIALS=firebase/service-account.json
# Option B: inline JSON (escape quotes if needed, or use file path above)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# === Google Sign-In (OAuth 2.0) ===
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Create: Web application + Android (package chat.ssc.secure, SHA-1 from debug keystore)
# Web client → GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET
# Authorized redirect URI (required): http://127.0.0.1:8000/api/auth/google/callback
#   Also add: http://<your-lan-ip>:8000/api/auth/google/callback for LAN phone testing
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://ssc-api-4jp3wuccwa-ew.a.run.app/api/auth/google/callback
NATIVE_OAUTH_REDIRECT=chat.ssc.secure://app
DESKTOP_OAUTH_REDIRECT=chat.ssc.secure.desktop://auth

# === Optional ===
APP_NAME=ssc-chat