# SSC - Super Secure Chat Backend Environment
# Copy to .env and fill in values. (.env is gitignored.)

# === REQUIRED ===
MONGO_URL=mongodb://localhost:27017
DB_NAME=ssc
JWT_SECRET=change-this-to-a-long-random-secret-at-least-48-characters-in-production

# === ENVIRONMENT ===
# development | production
ENV=development
LOG_LEVEL=INFO

# === RATE LIMITING (recommended for production / multi-worker) ===
# Start Redis: cd SSC-main && docker compose up -d redis
# Requires Docker Desktop running on Windows
REDIS_URL=redis://localhost:6379/0

# === CORS (comma-separated origins — no wildcards with credentials) ===
# Add your LAN IP if testing from phone browser: http://192.168.x.x:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Translation ===
# Uses free MyMemory API by default (no key). Optional Google provider — see TRANSLATION_PROVIDER below.
TRANSLATION_ENABLED=true
# TRANSLATION_PROVIDER=mymemory
# TRANSLATION_PROVIDER=google
# GOOGLE_TRANSLATE_API_KEY=

# === WebRTC TURN / ICE (required for calls across networks) ===
TURN_USERNAME=
TURN_CREDENTIAL=

# === Cloudflare Turnstile (recommended for production) ===
TURNSTILE_SITEKEY=
TURNSTILE_SECRET=

# === Web Push (VAPID) — PWA / browser ===
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_EMAIL=admin@ssc.local

# === Native Push (FCM + APNs) — Capacitor Android/iOS ===
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Option A: path to JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
# Option B: inline JSON (escape quotes if needed, or use file path above)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# === Google Sign-In (OAuth 2.0) ===
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Create: Web application + Android (package chat.ssc.secure, SHA-1 from debug keystore)
# Web client → GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET
# Authorized redirect URI (required): http://127.0.0.1:8000/api/auth/google/callback
#   Also add: http://192.168.1.154:8000/api/auth/google/callback for LAN phone testing
# Authorized JS origins: http://localhost:3000, http://localhost
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
FRONTEND_OAUTH_REDIRECT=http://localhost:3000
NATIVE_OAUTH_REDIRECT=http://localhost

# === Optional ===
APP_NAME=ssc-chat