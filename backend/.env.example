SSC_ENV=development
MONGO_URL=mongodb://localhost:27017
MONGO_DB=ssc
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000
SSC_ENFORCE_INSTALLED_CLIENT=false

# Tier D — security & abuse (Cloud Run toggles)
SSC_CAPTCHA_REQUIRED=false
SSC_TURNSTILE_SECRET=
SSC_TURNSTILE_SITE_KEY=
SSC_NEW_ACCOUNT_GRACE_HOURS=24
SSC_NEW_ACCOUNT_DM_LIMIT=10
SSC_NEW_ACCOUNT_DM_WINDOW_SEC=3600
SSC_ABUSE_REPORT_THRESHOLD=3
SSC_ABUSE_REPORT_WINDOW_HOURS=24
SSC_ABUSE_RATE_LIMIT_HOURS=24

# Google OAuth (optional — https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000