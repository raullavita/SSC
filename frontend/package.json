{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "@capacitor/app": "^7.0.1",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/push-notifications": "^7.0.1",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "5.101.1",
    "axios": "1.18.1",
    "mediasoup-client": "3.7.18",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "react-scripts": "5.0.1",
    "sonner": "2.0.7",
    "tailwindcss-animate": "1.0.7"
  },
  "optionalDependencies": {
    "@signalapp/libsignal-client": "0.96.4"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "build:mobile": "craco build",
    "build:phone": "craco build",
    "build:firebase": "craco build",
    "build:desktop": "set REACT_APP_ELECTRON=true&& craco build",
    "desktop:dev": "yarn build:desktop && cd desktop && yarn start",
    "desktop:build:win": "yarn build:desktop && cd desktop && yarn install && yarn build:win",
    "desktop:build:mac": "yarn build:desktop && cd desktop && yarn install && yarn build:mac",
    "test": "craco test",
    "test:ci": "craco test --watchAll=false --passWithNoTests",
    "cap:init": "cap init \"SSC\" chat.ssc.secure --web-dir build",
    "cap:sync": "yarn build:firebase && cap sync",
    "cap:sync:lan": "yarn build:phone && cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "7.21.11",
    "@capacitor/android": "^7.2.0",
    "@capacitor/cli": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "@craco/craco": "7.1.0",
    "@eslint/js": "9.39.4",
    "@testing-library/dom": "10.4.1",
