# SSC Frontend Environment Variables (Create React App + craco)
# Copy to .env (or .env.local) in this directory.
# REACT_APP_* vars are embedded at build time.

# Backend API base URL (no trailing slash)
REACT_APP_BACKEND_URL=http://localhost:8000

# SSC is installed-apps only — no browser-tab product surface.

# Cloudflare Turnstile site key (optional - backend gracefully allows if not set)
REACT_APP_TURNSTILE_SITEKEY=

# VAPID public key for push (optional)
REACT_APP_VAPID_PUBLIC=

# Google Play store listing URL (Q.62 — after Play Console publish)
# REACT_APP_GOOGLE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=chat.ssc.secure
