REACT_APP_API_URL=http://localhost:8000
REACT_APP_SSC_PLATFORM=electron
REACT_APP_SSC_VERSION=0.3.1
REACT_APP_SSC_BUILD=12

# Optional — GIS popup on desktop dev (same Web client ID as backend)
REACT_APP_GOOGLE_CLIENT_ID=

# Production website only — set true for Firebase landing (no chat routes)
# REACT_APP_SSC_LANDING_ONLY=true

# Production installed-client builds — require libsignal (Step 4)
# REACT_APP_SSC_REQUIRE_LIBCRYPTO=true