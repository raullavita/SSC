# Firebase Hosting — informational landing only (no web chat)
# REACT_APP_SSC_LANDING_ONLY=true

# Installed client production build (Electron / Android WebView)
REACT_APP_API_URL=https://api.supersecurechat.com
REACT_APP_SSC_PLATFORM=electron
REACT_APP_SSC_VERSION=0.1.0
REACT_APP_SSC_BUILD=0

# Step 4 — forbid dev crypto fallbacks in this build
REACT_APP_SSC_REQUIRE_LIBCRYPTO=true