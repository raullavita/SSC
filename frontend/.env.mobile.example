# Mobile (Capacitor) build — copy to .env.production.local before: yarn build:mobile
# Use your deployed HTTPS API (required for Web Crypto + calls on device).

REACT_APP_BACKEND_URL=https://api.yourdomain.com
REACT_APP_TURNSTILE_SITEKEY=
REACT_APP_VAPID_PUBLIC=

# Android emulator → host machine API: http://10.0.2.2:8000
# iOS simulator → host machine API: http://localhost:8000