{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/index.js",
    "src/setupTests.js",
    "src/**/__tests__/**/*.{js,jsx}",
    "src/**/*.test.{js,jsx}"
  ],
  "project": ["src/**/*.{js,jsx}"],
  "ignoreBinaries": ["eslint"],
  "ignoreDependencies": ["webpack", "@testing-library/user-event", "eslint-config-react-app"],
  "ignoreIssues": {
    "src/lib/abuseReport.js": ["exports"]
  }
}