# MongoDB Atlas Admin API — local only, never commit atlas-credentials.env
#
# 1. cloud.mongodb.com → Organization → Access Manager → API Keys → Create
# 2. Role: Project Owner (or Project Network Access Manager)
# 3. Paste keys below, then run: .\scripts\setup_atlas_cli.ps1
# 4. Harden IP list:        .\scripts\harden_atlas_network.ps1

ATLAS_PUBLIC_KEY=your-public-key
ATLAS_PRIVATE_KEY=your-private-key

# Optional — auto-detected from cluster name "ssc" if omitted
# ATLAS_GROUP_ID=24hexprojectid
# ATLAS_CLUSTER_NAME=ssc

# Only this CIDR stays on the project IP access list
SSC_ATLAS_KEEP_CIDR=34.140.240.41/32