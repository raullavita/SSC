# MongoDB Atlas credentials — local only, never commit atlas-credentials.env
#
# Service Account (recommended — Identity & Access → Applications → Create):
#   ATLAS_CLIENT_ID=...
#   ATLAS_CLIENT_SECRET=...
#
# Legacy API keys (if you have old keys instead):
#   ATLAS_PUBLIC_KEY=...
#   ATLAS_PRIVATE_KEY=...
#
# Then: .\scripts\setup_atlas_cli.ps1
#       .\scripts\harden_atlas_network.ps1

ATLAS_CLIENT_ID=your-client-id
ATLAS_CLIENT_SECRET=your-client-secret

# Optional
# ATLAS_GROUP_ID=24hexprojectid
# ATLAS_ORG_ID=24hexorgid

SSC_ATLAS_KEEP_CIDR=34.140.240.41/32

# Optional — Upstash Developer API (console.upstash.com → Account → API Keys)
# UPSTASH_EMAIL=your@email.com
# UPSTASH_API_KEY=your-upstash-api-key