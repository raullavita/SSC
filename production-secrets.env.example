# Optional production secrets — copy to production-secrets.env (gitignored).
# Used by scripts/apply_production_hardening.ps1 for Turnstile CAPTCHA.
#
# Create free keys: Cloudflare Dashboard → Turnstile → Add site → supersecurechat.com
SSC_TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
SSC_TURNSTILE_SECRET=REPLACE_WITH_TURNSTILE_SECRET